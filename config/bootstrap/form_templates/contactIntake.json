{
  "title": "Contact Intake",
  "name": "contactIntake",
  "path": "contactintake",
  "type": "form",
  "display": "form",
  "tags": [
    "Underwriting"
  ],
  "access": [
    {
      "type": "read_all",
      "roles": [
        "anonymous",
        "authenticated",
        "staff",
        "management",
        "administrator"
      ]
    }
  ],
  "submissionAccess": [
    {
      "type": "create_own",
      "roles": [
        "anonymous"
      ]
    },
    {
      "type": "read_all",
      "roles": [
        "authenticated",
        "staff",
        "management",
        "administrator"
      ]
    },
    {
      "type": "update_all",
      "roles": [
        "staff",
        "management",
        "administrator"
      ]
    },
    {
      "type": "delete_all",
      "roles": [
        "management",
        "administrator"
      ]
    }
  ],
  "components": [
    {
      "label": "Contact Information",
      "key": "contactInfo",
      "type": "panel",
      "hideLabel": true,
      "input": false,
      "tableView": false,
      "components": [
        {
          "label": "First Name",
          "key": "firstName",
          "type": "textfield",
          "input": true,
          "tableView": true,
          "validate": {
            "required": true
          }
        },
        {
          "label": "Last Name",
          "key": "lastName",
          "type": "textfield",
          "input": true,
          "tableView": true,
          "validate": {
            "required": true
          }
        },
        {
          "label": "Email",
          "key": "email",
          "type": "email",
          "input": true,
          "tableView": true,
          "validate": {
            "required": true
          }
        },
        {
          "label": "Phone",
          "key": "phone",
          "type": "phoneNumber",
          "input": true,
          "tableView": true
        },
        {
          "label": "Organization",
          "key": "organization",
          "type": "textfield",
          "input": true,
          "tableView": true,
          "description": "Your company or organization name"
        }
      ]
    },
    {
      "label": "Message",
      "key": "message",
      "type": "textarea",
      "input": true,
      "tableView": false,
      "rows": 5,
      "description": "Tell us about your organization and how you'd like to partner with us."
    },
    {
      "label": "Source",
      "key": "source",
      "type": "hidden",
      "input": true,
      "tableView": false,
      "defaultValue": "website"
    },
    {
      "label": "Honeypot",
      "key": "honeypot",
      "type": "textfield",
      "input": true,
      "tableView": false,
      "customClass": "d-none",
      "description": "Leave this field blank"
    },
    {
      "label": "Request More Information",
      "key": "submit",
      "type": "button",
      "action": "submit",
      "theme": "primary",
      "input": true
    }
  ],
  "settings": {
    "ui": {
      "alternateTitle": "Contact Intake",
      "submissionsTitle": "Contact Intake List",
      "sortOrder": 1,
      "marketingContent": {
        "headline": "Join the Movement: Sustain the Rhythm of Community Radio",
        "tagline": "An independent, community-funded radio station serving as an amplifier for music and social movements. For decades, we've remained unwavering and independent — accountable only to the listeners who power our mission.",
        "stats": [
          { "icon": "fas fa-users",           "title": "A Deeply Rooted Community", "body": "Over 53% of our listeners are African American, and the majority are over the age of 55." },
          { "icon": "fas fa-graduation-cap",  "title": "Influential & Educated",     "body": "78% hold advanced degrees; 50% report household income exceeding $120,000." },
          { "icon": "fas fa-broadcast-tower", "title": "Broad Reach",                "body": "Our 50,000-watt signal reaches across the region, complemented by a global digital footprint." }
        ],
        "valuesHeading": "What makes an ideal sponsor?",
        "values": [
          { "icon": "fas fa-heart",       "title": "Mission-Aligned & Justice-Oriented", "body": "Local music venues, grassroots nonprofits, and mission-driven small businesses whose work strengthens the cultural fabric of our region." },
          { "icon": "fas fa-handshake",   "title": "Committed to the Long Game",         "body": "Partners who understand that progressive social change is a multi-year effort and seek sustained commitment over quick, one-off spots." },
          { "icon": "fas fa-user-circle", "title": "Rooted in Candid Humanity",          "body": "Real organizations that embrace the humanistic, community spirit of our audience rather than a synthetic corporate identity." }
        ],
        "fccNote": "Unlike commercial radio, our sponsorship acknowledgments are fact-based and non-promotional. We welcome support from nonprofits, local businesses, and community organizations — but we never air sales pitches or advertising language.",
        "formTitle": "Request Sponsorship Information",
        "formSubtitle": "We usually respond within 1 business day."
      }
    },
    "groupPermissions": [
      {
        "resource": "UNDERWRITING_DEPT_PLACEHOLDER",
        "fieldName": "departments",
        "access": [
          "read_all"
        ],
        "_groupName": "Underwriting"
      }
    ],
    "tabulatorList": {
      "enabled": true,
      "layout": "fitColumns",
      "height": "60vh",
      "pagination": "local",
      "paginationSize": 25,
      "movableColumns": true,
      "placeholder": "No Contact Intake found.",
      "dataTransform": "contactIntakeDataTransform",
      "columns": [
        {
          "title": "First Name",
          "field": "data.firstName",
          "headerFilter": "input",
          "minWidth": 50
        },
        {
          "title": "Last Name",
          "field": "data.lastName",
          "headerFilter": "input",
          "minWidth": 50
        },
        {
          "title": "Organization",
          "field": "data.organization",
          "headerFilter": "input",
          "minWidth": 70
        },
        {
          "title": "Email",
          "field": "data.email",
          "width": 70,
          "headerFilter": "input"
        },
        {
          "title": "Message",
          "field": "data.message",
          "width": 150,
          "headerFilter": "input"
        }
      ]
    },
    "saveDraft": true,
    "saveDraftThrottle": 3000
  }
}
