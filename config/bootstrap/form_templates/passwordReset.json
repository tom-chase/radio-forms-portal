{
  "title": "Password Reset",
  "type": "form",
  "name": "passwordReset",
  "path": "passwordreset",
  "display": "form",
  "tags": [],
  "settings": {
    "ui": {
      "formsList": {
        "hidden": true
      }
    }
  },
  "components": [
    {
      "label": "Email",
      "tableView": true,
      "key": "email",
      "type": "email",
      "input": true,
      "persistent": true,
      "id": "epwr_email",
      "placeholder": "Enter your email address",
      "validate": {
        "required": true
      }
    },
    {
      "type": "button",
      "theme": "primary",
      "disableOnInvalid": true,
      "action": "submit",
      "block": true,
      "size": "md",
      "key": "submit",
      "tableView": false,
      "label": "Send Reset Link",
      "input": true
    }
  ],
  "access": [
    {
      "type": "read_all",
      "roles": [
        "anonymous",
        "authenticated"
      ]
    }
  ],
  "submissionAccess": [
    {
      "type": "create_own",
      "roles": [
        "anonymous",
        "authenticated"
      ]
    }
  ]
}
