                      {"label": "WV", "value": "WV"}, {"label": "WI", "value": "WI"},
                      {"label": "WY", "value": "WY"}
                    ]
                  }
                }
              ],
              "width": 3,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "label": "Zip Code",
                  "key": "addressZip",
                  "type": "textfield",
                  "input": true,
                  "tableView": false,
                  "inputMask": "99999"
                }
              ],
              "width": 3,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        }
      ]
    },
    {
      "label": "Billing Information",
      "key": "billingInfo",
      "type": "panel",
      "input": false,
      "tableView": false,
      "components": [
        {
          "label": "Billing address same as physical address",
          "key": "billingSameAsPhysical",
          "type": "checkbox",
          "input": true,
          "tableView": false
        },
        {
          "label": "Billing Street Address",
          "key": "billingStreet",
          "type": "textfield",
          "input": true,
          "tableView": false,
          "placeholder": "Street address",
          "customConditional": "show = !data.billingSameAsPhysical;",
          "calculateValue": "value = data.billingSameAsPhysical ? data.addressStreet : value;"
        },
        {
          "label": "Columns",
          "key": "billingAddressCityStateZip",
          "type": "columns",
          "input": false,
          "tableView": false,
          "customConditional": "show = !data.billingSameAsPhysical;",
          "columns": [
            {
              "components": [
                {
                  "label": "Billing City",
                  "key": "billingCity",
                  "type": "textfield",
                  "input": true,
                  "tableView": false,
                  "calculateValue": "value = data.billingSameAsPhysical ? data.addressCity : value;"
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "label": "Billing State",
                  "key": "billingState",
                  "type": "select",
                  "widget": "choicesjs",
                  "input": true,
                  "tableView": false,
                  "dataSrc": "values",
                  "calculateValue": "value = data.billingSameAsPhysical ? data.addressState : value;",
                  "data": {
                    "values": [
