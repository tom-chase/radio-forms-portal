                  "input": true,
                  "tableView": false
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "label": "State",
                  "key": "addressState",
                  "type": "select",
                  "widget": "choicesjs",
                  "input": true,
                  "tableView": false,
                  "dataSrc": "values",
                  "data": {
                    "values": [
                      {"label": "AL", "value": "AL"}, {"label": "AK", "value": "AK"},
                      {"label": "AZ", "value": "AZ"}, {"label": "AR", "value": "AR"},
                      {"label": "CA", "value": "CA"}, {"label": "CO", "value": "CO"},
                      {"label": "CT", "value": "CT"}, {"label": "DC", "value": "DC"},
                      {"label": "DE", "value": "DE"}, {"label": "FL", "value": "FL"},
                      {"label": "GA", "value": "GA"}, {"label": "HI", "value": "HI"},
